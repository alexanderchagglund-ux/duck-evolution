                    mesh.rotation.x = Math.PI/2;
                    group.add(mesh);
                } else if (type.type === 'mana_gem') {
                    const mesh = new THREE.Mesh(new THREE.OctahedronGeometry(type.size, 0), mat);
                    mesh.scale.set(0.5, 1.5, 0.5);
                    group.add(mesh);
                } else if (type.type === 'tesseract') {
                    const m1 = new THREE.Mesh(new THREE.BoxGeometry(type.size, type.size, type.size), new THREE.MeshBasicMaterial({color: type.color, wireframe: true}));
                    const m2 = new THREE.Mesh(new THREE.BoxGeometry(type.size*0.5, type.size*0.5, type.size*0.5), new THREE.MeshBasicMaterial({color: type.color, wireframe: true}));
                    group.add(m1, m2);
                } else if (type.type === 'dark_matter') {
                    const m1 = new THREE.Mesh(new THREE.SphereGeometry(type.size*0.6, 16, 16), mat);
                    const m2 = new THREE.Mesh(new THREE.SphereGeometry(type.size, 16, 16), new THREE.MeshLambertMaterial({color: 0x4c1d95, transparent: true, opacity: 0.5}));
                    group.add(m1, m2);
                } else if (type.type === 'abstract_thought') {
                    const m1 = new THREE.Mesh(new THREE.TorusGeometry(type.size*0.8, type.size*0.2, 8, 16), mat);
                    const m2 = new THREE.Mesh(new THREE.TorusGeometry(type.size*0.8, type.size*0.2, 8, 16), mat);
                    m2.rotation.x = Math.PI/2;
                    group.add(m1, m2);
                } else if (type.type === 'omni_seed') {
                    const m1 = new THREE.Mesh(new THREE.SphereGeometry(type.size*0.5, 16, 16), mat);
                    const m2 = new THREE.Mesh(new THREE.RingGeometry(type.size*0.8, type.size, 32), new THREE.MeshBasicMaterial({color: 0xffffff, side: THREE.DoubleSide}));
                    const m3 = new THREE.Mesh(new THREE.RingGeometry(type.size*0.8, type.size, 32), new THREE.MeshBasicMaterial({color: 0xffffff, side: THREE.DoubleSide}));
                    m2.rotation.x = Math.PI/2;
                    m3.rotation.y = Math.PI/2;
                    group.add(m1, m2, m3);
                } else if (type.type === 'source_code') {
                    const mesh = new THREE.Mesh(new THREE.BoxGeometry(type.size, type.size, type.size), new THREE.MeshBasicMaterial({color: 0x00ff00, wireframe: true}));
                    const core = new THREE.Mesh(new THREE.BoxGeometry(type.size*0.8, type.size*0.8, type.size*0.8), new THREE.MeshBasicMaterial({color: 0x000000}));
                    group.add(mesh, core);
                } else if (type.type === '4d_cube') {
                    const m1 = new THREE.Mesh(new THREE.BoxGeometry(type.size, type.size, type.size), new THREE.MeshBasicMaterial({color: 0x8b5cf6, wireframe: true}));
                    const m2 = new THREE.Mesh(new THREE.BoxGeometry(type.size*0.6, type.size*0.6, type.size*0.6), new THREE.MeshBasicMaterial({color: 0xc4b5fd, wireframe: true}));
                    m1.rotation.x = Math.PI/4; m2.rotation.y = Math.PI/4;
                    group.add(m1, m2);
                } else if (type.type === 'golden_apple') {
                    const m = new THREE.Mesh(new THREE.SphereGeometry(type.size, 16, 16), mat);
                    const stem = new THREE.Mesh(new THREE.CylinderGeometry(type.size*0.1, type.size*0.1, type.size*0.5), new THREE.MeshLambertMaterial({color: 0x78350f}));
                    stem.position.y = type.size;
                    group.add(m, stem);
                } else if (type.type === 'accretion_dust') {
                    const m = new THREE.Mesh(new THREE.TorusGeometry(type.size, type.size*0.3, 16, 32), mat);
                    m.rotation.x = Math.PI/2;
                    group.add(m);
                } else if (type.type === 'sim_token') {
                    const m = new THREE.Mesh(new THREE.IcosahedronGeometry(type.size, 0), new THREE.MeshBasicMaterial({color: type.color, wireframe: true}));
                    group.add(m);
                } else if (type.type === 'coffee_cup') {
                    const m = new THREE.Mesh(new THREE.CylinderGeometry(type.size*0.6, type.size*0.5, type.size*1.2, 16), mat);
                    const handle = new THREE.Mesh(new THREE.TorusGeometry(type.size*0.4, type.size*0.1, 8, 16), mat);
                    handle.position.x = type.size*0.6;
                    group.add(m, handle);
                }
                
                // PERFORMANCE: Disabled shadows on food to save thousands of draw calls
                // group.traverse(c => { if(c.isMesh) { c.castShadow = true; c.receiveShadow = true; }});
                
                foodPrefabCache[type.type] = group;
                return group.clone();
            }

            function getRandomFoodType() {
                let totalWeight = FOOD_TYPES.reduce((acc, curr) => acc + curr.weight, 0);
                let random = Math.random() * totalWeight;
                for (let type of FOOD_TYPES) {
                    if (random < type.weight) return type;
                    random -= type.weight;
                }
                return FOOD_TYPES[0];
            }

            function spawnFood(specificType = null) {
                const type = specificType || getRandomFoodType();
                const meshGroup = createFoodMesh(type);
                
                let spawnX, spawnZ;
                const area = POND_AREAS.find(a => a.foodType === type.type);
                
                if (area) {
                    // Spawn exclusively inside its designated biome
                    const r = Math.random() * (area.radius * 0.9);
                    const angle = Math.random() * Math.PI * 2;
                    spawnX = area.x + Math.cos(angle) * r;
                    spawnZ = area.z + Math.sin(angle) * r;
                } else if (type.type === 'seed') {
                    // Force starter food (seeds) to cluster around the (0,0) spawn area
                    // using a random radius up to 800 to ensure plenty of food for new players
                    const r = Math.random() * 800; 
                    const angle = Math.random() * Math.PI * 2;
                    spawnX = Math.cos(angle) * r;
                    spawnZ = Math.sin(angle) * r;
                } else {
                    // Spawn in open water, attempt to avoid biomes
                    let valid = false;
                    let attempts = 0;
                    while(!valid && attempts < 10) {
                        spawnX = (Math.random() - 0.5) * WORLD_SIZE;
                        spawnZ = (Math.random() - 0.5) * WORLD_SIZE;
                        valid = true;
                        for(let a of POND_AREAS) {
                            if (Math.hypot(spawnX - a.x, spawnZ - a.z) < a.radius) {
                                valid = false; break;
                            }
                        }
                        attempts++;
                    }
                }
                
                meshGroup.position.set(spawnX, 5, spawnZ);

                scene.add(meshGroup);
                foods.push({
                    mesh: meshGroup,
                    type: type,
                    floatOffset: Math.random() * Math.PI * 2
                });
            }

            // PERFORMANCE: Cache particle geometries and materials
            const sharedParticleGeo = new THREE.BoxGeometry(2, 2, 2);
            const particleMatCache = {};

            function createExplosion(pos, color, amount) {
                if (!particleMatCache[color]) {
                    particleMatCache[color] = new THREE.MeshBasicMaterial({ color: color }); // Basic is much faster
                }
                const mat = particleMatCache[color];
                
                // PERFORMANCE: Cap particles to 15 max to avoid extreme lag spikes
                const safeAmount = Math.min(amount, 15);

                for (let i = 0; i < safeAmount; i++) {
                    const mesh = new THREE.Mesh(sharedParticleGeo, mat);
                    mesh.position.copy(pos);
                    mesh.position.y += 5;
                    scene.add(mesh);
                    particles.push({
                        mesh: mesh,
                        vx: (Math.random() - 0.5) * 6,
                        vy: Math.random() * 5 + 2,
                        vz: (Math.random() - 0.5) * 6,
                        life: 1.0
                    });
                }
            }

            function showFloatingText(pos, text, colorCSS) {
                const div = document.createElement('div');
                div.innerText = text;
                div.className = 'absolute font-black text-2xl drop-shadow-[0_2px_2px_rgba(0,0,0,0.8)] pointer-events-none transform -translate-x-1/2 -translate-y-1/2';
                div.style.color = colorCSS;
                floatingContainer.appendChild(div);

                let life = 1.0;
                const startY = pos.y;
                
                function animateText() {
                    life -= 0.02;
                    if (life <= 0) {
                        div.remove();
                        return;
                    }
                    
                    const tempPos = pos.clone();
                    tempPos.y = startY + (1 - life) * 40;
                    
                    tempPos.project(camera);
                    const xScreen = (tempPos.x * 0.5 + 0.5) * window.innerWidth;
                    const yScreen = (tempPos.y * -0.5 + 0.5) * window.innerHeight;

                    div.style.left = `${xScreen}px`;
                    div.style.top = `${yScreen}px`;
                    div.style.opacity = life;
                    div.style.transform = `translate(-50%, -50%) scale(${1 + (1-life)*0.5})`;

                    requestAnimationFrame(animateText);
                }
                animateText();
            }

            function checkEvolution() {
                const currentStage = EVOLUTIONS[player.stageIndex];
                if (player.xp >= currentStage.maxExp && player.stageIndex < EVOLUTIONS.length - 1) {
                    player.xp -= currentStage.maxExp;
                    player.stageIndex++;
                    
                    const newStage = EVOLUTIONS[player.stageIndex];
                    loadPlayerModel(player.stageIndex);
                    createExplosion(player.group.position, 0xffd700, 40);
                    
                    levelUpEmoji.innerText = newStage.emoji;
                    levelUpName.innerText = newStage.name;
                    levelUpNotification.style.opacity = '1';
                    levelUpContent.style.transform = 'scale(1.1)';
                    
                    setTimeout(() => levelUpContent.style.transform = 'scale(1)', 100);
                    setTimeout(() => levelUpNotification.style.opacity = '0', 3000);

                    // Auto-save on evolution
                    saveProgress();
                }
                updateUI();
            }

            function updateUI() {
                const stage = EVOLUTIONS[player.stageIndex];
                levelUi.innerText = stage.level;
                duckNameUi.innerText = stage.name;
                currentEmojiUi.innerText = stage.emoji;
                scoreUi.innerText = score;
                
                if (stage.maxExp === Infinity) {
                    xpText.innerText = "MAX LEVEL";
                    xpFill.style.width = "100%";
                    xpFill.className = "h-full bg-gradient-to-r from-yellow-400 to-yellow-200 rounded-full w-full relative";
                } else {
                    xpText.innerText = `${player.xp} / ${stage.maxExp}`;
                    const percentage = Math.min(100, (player.xp / stage.maxExp) * 100);
                    xpFill.style.width = `${percentage}%`;
                }
            }

            // Initialize Game
            loadPlayerModel(0);
            for (let i = 0; i < FOOD_COUNT; i++) spawnFood();

            // Animation Loop
            const clock = new THREE.Clock();
            let lastSyncTime = 0;
            
            function animate() {
                requestAnimationFrame(animate);
                const delta = clock.getDelta();
                const time = clock.getElapsedTime();
                const stage = EVOLUTIONS[player.stageIndex];

                // 1. Inputs & Steering (Tank Controls)
                let dx = 0;
                let dz = 0;

                // Handle keyboard turning (slowed down from 0.05 to 0.015)
                if (keys.a || keys.arrowleft) player.targetRotation += 0.015;
                if (keys.d || keys.arrowright) player.targetRotation -= 0.015;

                // Handle forward/backward
                let forward = 0;
                if (keys.w || keys.arrowup) forward = 1;
                if (keys.s || keys.arrowdown) forward = -0.6; // Backward is slightly slower

                if (isLeftMouseDown) {
                    raycaster.setFromCamera(mouse, camera);
                    const intersects = raycaster.intersectObject(raycastPlane);
                    if (intersects.length > 0) {
                        mouseWorldPos.copy(intersects[0].point);
                        const dir = new THREE.Vector3().subVectors(mouseWorldPos, player.group.position);
                        dir.y = 0;
                        if (dir.length() > 5) {
                            // Steer towards mouse position
                            player.targetRotation = Math.atan2(dir.x, dir.z);
                            forward = 1; // Move forward when steering with mouse
                        }
                    }
                }
                
                if (forward !== 0) {
                    // Move forward based on where we are ACTUALLY rotated (makes turns much wider/slower)
                    dx = Math.sin(player.group.rotation.y) * forward;
                    dz = Math.cos(player.group.rotation.y) * forward;
                }

                // 2. Velocity & Movement
                player.vx += (dx * stage.speed - player.vx) * 0.1;
                player.vz += (dz * stage.speed - player.vz) * 0.1;

                player.group.position.x += player.vx;
                player.group.position.z += player.vz;

                // Clamp to bounds
                const limit = WORLD_SIZE / 2 - stage.size;
                player.group.position.x = Math.max(-limit, Math.min(limit, player.group.position.x));
                player.group.position.z = Math.max(-limit, Math.min(limit, player.group.position.z));

                // Area Barrier Collision & Animation
                POND_AREAS.forEach(area => {
                    if (area.barrierMesh) {
                        // Check if player's current level (stageIndex + 1) unlocks this area
                        if (player.stageIndex + 1 >= area.unlockLevel) {
                            area.barrierMesh.visible = false;
                        } else {
                            area.barrierMesh.visible = true;
                            area.barrierMesh.rotation.y -= delta * 0.2; // Spin forcefield
                            
                            // Prevent entering
                            const dist = Math.hypot(player.group.position.x - area.x, player.group.position.z - area.z);
                            if (dist < area.radius + stage.size) {
                                // Push player out of barrier
                                const angle = Math.atan2(player.group.position.z - area.z, player.group.position.x - area.x);
                                player.group.position.x = area.x + Math.cos(angle) * (area.radius + stage.size);
                                player.group.position.z = area.z + Math.sin(angle) * (area.radius + stage.size);
                                player.vx *= -0.5; // Kill momentum
                                player.vz *= -0.5;
                                
                                // Show floating rejection text
                                if (!area.lastHitTime || time - area.lastHitTime > 1.5) {
                                    area.lastHitTime = time;
                                    showFloatingText(player.group.position, `Requires Level ${area.unlockLevel}!`, '#ef4444');
                                }
                            }
                        }
                    }
                });

                // 3. Rotation & Animation
                const speedMag = Math.hypot(player.vx, player.vz);
                if (speedMag > 0.1) {
                    // player.targetRotation is now explicitly managed by inputs, no longer overwritten by velocity!
                    player.wobble += speedMag * 0.15; // Increased wobble slightly because movement is slower
                    
                    // Wobble inner model cleanly
                    player.modelGroup.rotation.z = Math.sin(player.wobble) * 0.1;
                    player.modelGroup.position.y = Math.abs(Math.sin(player.wobble * 2)) * (stage.size * 0.15);
                    
                    // Wing Flapping
                    if(player.group.userData.wings && player.group.userData.wings.length >= 2) {
                        for(let w=0; w<player.group.userData.wings.length; w+=2) {
                            if(player.group.userData.wings[w+1]) {
                                player.group.userData.wings[w].rotation.z = Math.sin(player.wobble*2)*0.5;
                                player.group.userData.wings[w+1].rotation.z = -Math.sin(player.wobble*2)*0.5;
                            }
                        }
                    }

                    if(Math.random() < 0.2) {
                        createExplosion(new THREE.Vector3(player.group.position.x, 0, player.group.position.z), 0xffffff, 1);
                    }
                } else {
                    player.modelGroup.rotation.z *= 0.9;
                    player.modelGroup.position.y *= 0.9;
                    if(player.group.userData.wings && player.group.userData.wings.length >= 2) {
                        for(let w=0; w<player.group.userData.wings.length; w++) {
                            player.group.userData.wings[w].rotation.z *= 0.9;
                        }
                    }
                }

                // Handle generic spinners attached to the model
                if (player.modelGroup.userData.spinners) {
                    player.modelGroup.userData.spinners.forEach((spinner, idx) => {
                        spinner.rotation.x += 0.01 + (idx*0.005);
                        spinner.rotation.y += 0.02;
                        spinner.rotation.z += 0.015;
                    });
                }

                // Smooth rotation of root object
                let rotDiff = player.targetRotation - player.group.rotation.y;
                while(rotDiff > Math.PI) rotDiff -= Math.PI * 2;
                while(rotDiff < -Math.PI) rotDiff += Math.PI * 2;
                // Slower visual catching up to target rotation to feel heavier and wider
                player.group.rotation.y += rotDiff * 0.04;

                // MULTIPLAYER SYNC & OTHER PLAYER ANIMATION
                if (isOnline && userId && playerDocRef) {
                    const now = Date.now();
                    if (now - lastSyncTime > 100) { // Sync to server 10 times a second
                        setDoc(playerDocRef, {
                            x: player.group.position.x,
                            z: player.group.position.z,
                            rot: player.group.rotation.y,
                            stageIndex: player.stageIndex,
                            wobble: player.wobble,
                            timestamp: now
                        }, { merge: true }).catch(e => console.error(e));
                        lastSyncTime = now;
                    }
                }

                for (const uid in otherPlayers) {
                    const op = otherPlayers[uid];
                    
                    // Lerp position for smooth movement despite network delay
                    op.group.position.x += (op.targetX - op.group.position.x) * 0.1;
                    op.group.position.z += (op.targetZ - op.group.position.z) * 0.1;

                    let oRotDiff = op.targetRot - op.group.rotation.y;
                    while(oRotDiff > Math.PI) oRotDiff -= Math.PI * 2;
                    while(oRotDiff < -Math.PI) oRotDiff += Math.PI * 2;
                    op.group.rotation.y += oRotDiff * 0.1;

                    // Apply animation wobble locally based on their speed
                    const speed = Math.hypot(op.targetX - op.group.position.x, op.targetZ - op.group.position.z);
                    if (speed > 0.5) {
                        op.wobble += speed * 0.05;
                        const stageSize = EVOLUTIONS[op.stageIndex].size;
                        op.modelGroup.rotation.z = Math.sin(op.wobble) * 0.1;
                        op.modelGroup.position.y = Math.abs(Math.sin(op.wobble * 2)) * (stageSize * 0.15);

                        if(op.group.userData.wings && op.group.userData.wings.length >= 2) {
                            for(let w=0; w<op.group.userData.wings.length; w+=2) {
                                if(op.group.userData.wings[w+1]) {
                                    op.group.userData.wings[w].rotation.z = Math.sin(op.wobble*2)*0.5;
                                    op.group.userData.wings[w+1].rotation.z = -Math.sin(op.wobble*2)*0.5;
                                }
                            }
                        }
                    } else {
                        op.modelGroup.rotation.z *= 0.9;
                        op.modelGroup.position.y *= 0.9;
                        if(op.group.userData.wings && op.group.userData.wings.length >= 2) {
                            for(let w=0; w<op.group.userData.wings.length; w++) {
                                op.group.userData.wings[w].rotation.z *= 0.9;
                            }
                        }
                    }

                    // Spin parts for other players if they exist
                    if (op.modelGroup.userData.spinners) {
                        op.modelGroup.userData.spinners.forEach((spinner, idx) => {
                            spinner.rotation.x += 0.01 + (idx*0.005);
                            spinner.rotation.y += 0.02;
                            spinner.rotation.z += 0.015;
                        });
                    }
                }

                // Infinite food regeneration: actively keep the pond completely full
                let foodsToSpawn = Math.min(5, MAX_FOOD - foods.length);
                for (let f = 0; f < foodsToSpawn; f++) {
                    spawnFood();
                }

                // 4. Food Logic
                for (let i = foods.length - 1; i >= 0; i--) {
                    const food = foods[i];
                    
                    // PERFORMANCE: Use squared distance (massively faster than regular distance)
                    const distSq = player.group.position.distanceToSquared(food.mesh.position);
                    
                    // PERFORMANCE: Only calculate math, animate, and check collision for food close to the player
                    if (distSq < 4000000) { // 2000 * 2000
                        food.mesh.position.y = 5 + Math.sin(time * 3 + food.floatOffset) * 3;
                        food.mesh.rotation.y += 0.02;
                        food.mesh.rotation.x = Math.sin(time + food.floatOffset) * 0.2;

                        const collisionDist = stage.size + food.type.size;
                        if (distSq < collisionDist * collisionDist) {
                            player.xp += food.type.xp;
                            score += food.type.xp;
                            
                            createExplosion(food.mesh.position, food.type.color, 8);
                            showFloatingText(food.mesh.position, `+${food.type.xp}`, '#4ade80');
                            
                            const eatenType = food.type; // Save type before splicing
                            
                            scene.remove(food.mesh);
                            foods.splice(i, 1);
                            
                            // 1-for-1 Exact Replacement! This prevents biomes from ever emptying out.
                            spawnFood(eatenType);
                            
                            checkEvolution();
                        }
                    }
                }

                // 5. Particles
                for (let i = particles.length - 1; i >= 0; i--) {
                    const p = particles[i];
                    p.mesh.position.x += p.vx;
                    p.mesh.position.y += p.vy;
                    p.mesh.position.z += p.vz;
                    p.vy -= 0.2; // Gravity
                    
                    p.mesh.rotation.x += 0.1;
                    p.mesh.rotation.y += 0.1;
                    
                    p.life -= 0.03;
                    p.mesh.scale.setScalar(Math.max(0, p.life));
                    
                    if (p.life <= 0 || p.mesh.position.y < -5) {
                        scene.remove(p.mesh);
                        particles.splice(i, 1);
                    }
                }

                // 6. Camera Follow (3rd Person Chase)
                const camDist = (100 + stage.size * 2.5) * cameraZoom;
                const camHeight = (50 + stage.size * 1.5) * cameraZoom;
                
                // Auto-recenter camera gently if moving and not dragging
                const isMoving = forward !== 0 || isLeftMouseDown || keys.a || keys.arrowleft || keys.d || keys.arrowright;
                if (!isRightMouseDown && isMoving) {
                    cameraAngleOffset *= 0.95;
                }

                // Track firmly behind the duck based on its actual rotation + the drag offset
                const camRot = player.group.rotation.y + cameraAngleOffset;

                const targetCamPos = new THREE.Vector3(
                    player.group.position.x - Math.sin(camRot) * camDist,
                    player.group.position.y + camHeight,
                    player.group.position.z - Math.cos(camRot) * camDist
                );

                // Add slight panning if left mouse is down for a dynamic feel
                if (isLeftMouseDown) {
                    targetCamPos.x += mouse.x * 20;
                    targetCamPos.z -= mouse.y * 20;
                }

                camera.position.lerp(targetCamPos, 0.06);

                // Look smoothly slightly ahead of the camera's angle
                const targetLookAt = new THREE.Vector3(
                    player.group.position.x + Math.sin(camRot) * 20,
                    player.group.position.y + stage.size,
                    player.group.position.z + Math.cos(camRot) * 20
                );

                if (!camera.userData.targetLookAt) {
                    camera.userData.targetLookAt = new THREE.Vector3().copy(player.group.position);
                }
                camera.userData.targetLookAt.lerp(targetLookAt, 0.1);
                camera.lookAt(camera.userData.targetLookAt);

                renderer.render(scene, camera);
            }

            animate();
        }
    </script>
</body>
