                        container.add(box);
                    }
                    const head = new THREE.Mesh(new THREE.BoxGeometry(bSize*0.8, bSize*0.8, bSize*0.8), glitchMat2);
                    head.position.set(0, bSize*2.5, bSize*0.8);
                    container.add(head);
                    const beak = new THREE.Mesh(new THREE.BoxGeometry(bSize*0.4, bSize*0.2, bSize*0.8), glitchMat1);
