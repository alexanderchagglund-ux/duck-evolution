                    wings.push(createWing(bSize*0.7, bSize*0.15, bSize*1.0, bSize*2.0, bodyMat));
                    wings.push(createWing(-bSize*0.7, bSize*0.15, bSize*1.0, bSize*2.0, bodyMat));

                } else if (stageIndex === 4) { // Prehistoric Quack (Dino Duck)
