                    wings.push(createWing(-bSize*0.8, bSize*0.2, bSize*0.8, bSize*1.5, bodyMat));

                } else if (stageIndex === 5) { // Mecha Mallard (Robot)
                    const body = new THREE.Mesh(new THREE.CylinderGeometry(bSize*0.8, bSize*0.9, bSize*1.8, 8), bodyMat);
