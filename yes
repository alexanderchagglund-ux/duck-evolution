                    const glitchMat2 = new THREE.MeshBasicMaterial({color: 0x10b981, wireframe: true});
                    for(let i=0; i<8; i++) {
                        const box = new THREE.Mesh(new THREE.BoxGeometry(bSize*0.6, bSize*0.6, bSize*0.6), i%2==0 ? glitchMat1 : glitchMat2);
