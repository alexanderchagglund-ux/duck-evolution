                    tail.position.set(0, bSize*1.3, -bSize*1.4);
                    container.add(tail);

                    // S-Curve Neck
                    const numNeckParts = 8;
                    for(let i=0; i<numNeckParts; i++) {
                        const t = i / (numNeckParts - 1);
                        const ny = bSize + t * bSize * 1.8;
                        const nz = bSize*0.8 + Math.sin(t * Math.PI * 1.5) * bSize * 0.4;
                        const nSize = bSize*0.3 * (1 - t*0.3);
                        const neckPart = new THREE.Mesh(new THREE.SphereGeometry(nSize, 16, 16), headMat);
                        neckPart.position.set(0, ny, nz);
                        container.add(neckPart);
                    }

                    const hY = bSize + bSize * 1.8;
                    const hZ = bSize*0.8 + Math.sin(Math.PI * 1.5) * bSize * 0.4 + bSize*0.2;
                    
                    const head = new THREE.Mesh(new THREE.SphereGeometry(bSize*0.4, 16, 16), headMat);
                    head.position.set(0, hY, hZ);
