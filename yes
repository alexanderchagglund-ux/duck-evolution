                    wings.push(createWing(bSize, bSize*0.2, bSize*1.5, bSize*1.5, bodyMat));
                    wings.push(createWing(-bSize, bSize*0.2, bSize*1.5, bSize*1.5, bodyMat));

                } else if (stageIndex === 11) { // Celestial Phoenix
