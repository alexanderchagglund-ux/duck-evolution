                    const snout = new THREE.Mesh(new THREE.BoxGeometry(bSize*0.6, bSize*0.4, bSize*0.8), headMat);
                    snout.position.set(0, bSize*1.9, bSize*2.0);
                    container.add(snout);
                    
                    const hornMat = new THREE.MeshLambertMaterial({color: 0xffffff});
                    const hornL = new THREE.Mesh(new THREE.ConeGeometry(bSize*0.15, bSize*1.2, 8), hornMat);
                    hornL.rotation.x = -Math.PI / 4;
                    hornL.rotation.z = -Math.PI / 8;
                    hornL.position.set(bSize*0.4, bSize*2.6, bSize*0.8);
                    container.add(hornL);

                    const hornR = new THREE.Mesh(new THREE.ConeGeometry(bSize*0.15, bSize*1.2, 8), hornMat);
                    hornR.rotation.x = -Math.PI / 4;
                    hornR.rotation.z = Math.PI / 8;
                    hornR.position.set(-bSize*0.4, bSize*2.6, bSize*0.8);
                    container.add(hornR);

                    const glowEyeMat = new THREE.MeshBasicMaterial({color: 0x3b82f6});
                    const eyeL = new THREE.Mesh(new THREE.SphereGeometry(bSize*0.15, 8, 8), glowEyeMat);
                    eyeL.position.set(bSize*0.4, bSize*2.1, bSize*1.6);
                    const eyeR = eyeL.clone();
                    eyeR.position.set(-bSize*0.4, bSize*2.1, bSize*1.6);
                    container.add(eyeL, eyeR);

                    // Dragon Wings
                    function createDragonWing(x) {
                        const pivot = new THREE.Group();
                        pivot.position.set(x, bSize*1.5, 0);
                        
                        const wingShape = new THREE.Shape();
                        wingShape.moveTo(0, 0);
                        wingShape.lineTo(bSize*2, bSize*1.5);
                        wingShape.lineTo(bSize*2.5, bSize*0.5);
                        wingShape.lineTo(bSize*1.5, -bSize*1.0);
                        wingShape.lineTo(0, 0);
                        
                        const extrudeSettings = { depth: bSize*0.1, bevelEnabled: false };
                        const geometry = new THREE.ExtrudeGeometry(wingShape, extrudeSettings);
                        geometry.translate(0, 0, -bSize*0.05);

                        const mesh = new THREE.Mesh(geometry, bodyMat);
                        if(x < 0) mesh.scale.set(-1, 1, 1);
                        
                        pivot.add(mesh);
                        container.add(pivot);
                        return pivot;
                    }

                    wings.push(createDragonWing(bSize*0.4));
                    wings.push(createDragonWing(-bSize*0.4));

                } else if (stageIndex === 7) { // Galactic Emperor
                    const body = new THREE.Mesh(new THREE.SphereGeometry(bSize, 16, 16), bodyMat);
