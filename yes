                    const beak = new THREE.Mesh(new THREE.ConeGeometry(bSize*0.2, bSize*0.8, 8), beakMat);
                    beak.rotation.x = Math.PI / 2;
                    beak.position.set(0, hY - bSize*0.05, hZ + bSize*0.6);
                    container.add(beak);

                    addEye(bSize*0.2, hY + bSize*0.1, hZ + bSize*0.2, bSize*0.06);
