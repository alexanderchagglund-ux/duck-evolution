<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Duck Evolution</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <style>
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background-color: #7dd3fc;
            touch-action: none;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        #gameCanvas {
            display: block;
        }
        .ui-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }
        #xp-fill {
            transition: width 0.3s ease-out;
        }
    </style>
</head>
<body>

    <!-- Canvas for the Game -->
    <canvas id="gameCanvas"></canvas>

    <!-- UI Overlay -->
    <div class="ui-layer flex flex-col justify-between p-4 md:p-6">
        <!-- Top Bar -->
        <div class="flex justify-between items-start">
            <div class="bg-white/80 backdrop-blur-sm rounded-xl p-3 shadow-lg border border-white/50 pointer-events-auto">
                <h1 class="text-xl md:text-2xl font-bold text-gray-800 tracking-tight">Duck Evolution <span id="current-emoji">🐥</span></h1>
                <p class="text-sm font-semibold text-gray-600 mt-1">Level <span id="level-ui">1</span>: <span id="duck-name" class="text-blue-600">Baby Duck</span></p>
                <div class="mt-2 text-sm text-gray-500 font-medium">Score: <span id="score-ui">0</span></div>
            </div>
            
            <div class="flex flex-col items-end gap-2">
                <div class="bg-white/80 backdrop-blur-sm rounded-xl p-3 shadow-lg border border-white/50 text-right pointer-events-auto">
                    <p class="text-xs md:text-sm text-gray-600 font-semibold mb-1">Controls</p>
                    <p class="text-xs text-gray-500">🖱️ Mouse / Touch to steer</p>
                    <p class="text-xs text-gray-500">⌨️ WASD / Arrows to move</p>
                    <p class="text-xs text-gray-500">🖱️ Scroll to zoom</p>
                    <p class="text-xs text-gray-500">🖱️ Right-click drag to look</p>
                </div>
                
                <!-- Account / Save Controls -->
                <div class="bg-white/80 backdrop-blur-sm rounded-xl p-3 shadow-lg border border-white/50 text-right pointer-events-auto flex flex-col gap-2 w-full">
                    <div id="save-indicator" class="text-xs font-bold text-green-500 opacity-0 transition-opacity text-center">Progress Saved! ✓</div>
                    <button id="save-btn" class="bg-blue-500 hover:bg-blue-600 text-white text-xs font-bold py-1.5 px-3 rounded shadow transition-colors w-full">Save Game</button>
                    <button id="reset-btn" class="bg-red-500 hover:bg-red-600 text-white text-xs font-bold py-1.5 px-3 rounded shadow transition-colors w-full">Reset Progress</button>
                </div>
                
                <!-- Multiplayer Room Controls -->
                <div class="bg-white/80 backdrop-blur-sm rounded-xl p-3 shadow-lg border border-white/50 text-right pointer-events-auto flex flex-col gap-2 w-full">
                    <p class="text-xs font-semibold text-gray-600 text-center">Multiplayer Room</p>
                    <input type="text" id="room-input" value="Global" class="w-full px-2 py-1 text-xs border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-blue-500 text-center font-bold text-gray-700">
                    <button id="join-room-btn" class="bg-green-500 hover:bg-green-600 text-white text-xs font-bold py-1.5 px-3 rounded shadow transition-colors w-full">Join Room</button>
                </div>
            </div>
        </div>

        <!-- Bottom Bar (XP) -->
        <div class="w-full max-w-2xl mx-auto mb-4 pointer-events-auto">
            <div class="flex justify-between text-white font-bold text-sm mb-1 drop-shadow-md px-1">
                <span>XP</span>
                <span id="xp-text">0 / 50</span>
            </div>
            <div class="h-6 w-full bg-gray-900/40 rounded-full border-2 border-white/50 overflow-hidden shadow-inner relative">
                <div id="xp-fill" class="h-full bg-gradient-to-r from-blue-400 to-cyan-300 rounded-full w-0 relative">
                    <div class="absolute top-0 right-0 bottom-0 left-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI4IiBoZWlnaHQ9IjgiPgo8cmVjdCB3aWR0aD0iOCIgaGVpZ2h0PSI4IiBmaWxsPSIjZmZmIiBmaWxsLW9wYWNpdHk9IjAuMSIvPgo8L3N2Zz4=')] opacity-50"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Level Up Notification -->
    <div id="level-up-notification" class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-0 transition-opacity duration-500 z-50">
        <div class="text-center transform scale-90 transition-transform duration-500" id="level-up-content">
            <div class="text-6xl md:text-9xl drop-shadow-2xl mb-4" id="level-up-emoji">🦆</div>
            <h2 class="text-4xl md:text-6xl font-black text-white drop-shadow-[0_4px_4px_rgba(0,0,0,0.5)] tracking-wider uppercase text-transparent bg-clip-text bg-gradient-to-b from-yellow-300 to-yellow-600">EVOLUTION!</h2>
            <p class="text-xl md:text-2xl text-white font-bold mt-2 drop-shadow-lg">You are now a <span id="level-up-name">Normal Duck</span>!</p>
        </div>
    </div>

    <!-- Container for floating text -->
    <div id="floating-text-container" class="absolute inset-0 pointer-events-none overflow-hidden z-40"></div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, onAuthStateChanged, signInWithCustomToken } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, collection, doc, setDoc, getDoc, onSnapshot, deleteDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        init3DGame();

        function init3DGame() {
            // UI Elements
            const xpFill = document.getElementById('xp-fill');
            const xpText = document.getElementById('xp-text');
            const levelUi = document.getElementById('level-ui');
            const duckNameUi = document.getElementById('duck-name');
            const currentEmojiUi = document.getElementById('current-emoji');
            const scoreUi = document.getElementById('score-ui');
            const levelUpNotification = document.getElementById('level-up-notification');
            const levelUpContent = document.getElementById('level-up-content');
            const levelUpEmoji = document.getElementById('level-up-emoji');
            const levelUpName = document.getElementById('level-up-name');
            const floatingContainer = document.getElementById('floating-text-container');

            // Three.js Setup
            const canvas = document.getElementById('gameCanvas');
            const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.shadowMap.enabled = true;
            // PERFORMANCE: Changed to BasicShadowMap which is much faster than PCFSoftShadowMap
            renderer.shadowMap.type = THREE.BasicShadowMap;

            const scene = new THREE.Scene();
            scene.background = new THREE.Color(0x7dd3fc); // Sky blue
            // Massively reduced fog density to see even further clearly
            scene.fog = new THREE.FogExp2(0x7dd3fc, 0.00002);

            // Increased render distance to see distant biomes
            const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 1, 30000);
            camera.position.set(0, 100, 200); // Set initial pos to avoid fly-in glitch

            // Lighting
            const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
            scene.add(ambientLight);

            const dirLight = new THREE.DirectionalLight(0xffffff, 0.9);
            dirLight.position.set(200, 300, 100);
            dirLight.castShadow = true;
            dirLight.shadow.camera.left = -600;
            dirLight.shadow.camera.right = 600;
            dirLight.shadow.camera.top = 600;
            dirLight.shadow.camera.bottom = -600;
            // PERFORMANCE: Halved shadow map resolution to boost FPS
            dirLight.shadow.mapSize.width = 1024;
            dirLight.shadow.mapSize.height = 1024;
            scene.add(dirLight);

            // Ground / Water
            const groundGeo = new THREE.PlaneGeometry(50000, 50000); // Massively expanded for 25 biomes
            const groundMat = new THREE.MeshLambertMaterial({ color: 0x38bdf8 }); // Water color
            const ground = new THREE.Mesh(groundGeo, groundMat);
            ground.rotation.x = -Math.PI / 2;
            ground.receiveShadow = true;
            scene.add(ground);

            const raycastPlane = new THREE.Mesh(groundGeo, new THREE.MeshBasicMaterial({ visible: false }));
            raycastPlane.rotation.x = -Math.PI / 2;
            scene.add(raycastPlane);

            // --- POND AREAS (BIOMES) perfectly spaced in a massive concentric grid to prevent overlaps ---
            const POND_AREAS = [
                // Ring 1 (Close to center)
                { type: 'shallow', color: 0xfde047, x: 2000, z: 2000, radius: 400, unlockLevel: 2, foodType: 'bread' },
                { type: 'mud', color: 0xa16207, x: -2000, z: 2000, radius: 450, unlockLevel: 3, foodType: 'bug' },
                { type: 'deep', color: 0x0284c7, x: -2000, z: -2000, radius: 500, unlockLevel: 4, foodType: 'fish' },
                { type: 'mystic', color: 0xa855f7, x: 2000, z: -2000, radius: 350, unlockLevel: 5, foodType: 'star' },
                // Ring 2
                { type: 'cyber', color: 0x06b6d4, x: 5000, z: 0, radius: 400, unlockLevel: 6, foodType: 'battery' },
                { type: 'cosmic', color: 0x0f172a, x: -5000, z: 0, radius: 450, unlockLevel: 7, foodType: 'galaxy_core' },
                { type: 'royal', color: 0xfcd34d, x: 0, z: 5000, radius: 400, unlockLevel: 8, foodType: 'golden_egg' },
                { type: 'quantum', color: 0x14b8a6, x: 0, z: -5000, radius: 450, unlockLevel: 9, foodType: 'quark' },
                // Ring 3
                { type: 'multiverse', color: 0xffffff, x: 5000, z: 5000, radius: 500, unlockLevel: 10, foodType: 'universe' },
                { type: 'chrono', color: 0xb45309, x: -5000, z: 5000, radius: 700, unlockLevel: 11, foodType: 'hourglass' },
                { type: 'magma', color: 0xef4444, x: -5000, z: -5000, radius: 750, unlockLevel: 12, foodType: 'sun_flame' },
                { type: 'glitch', color: 0x10b981, x: 5000, z: -5000, radius: 800, unlockLevel: 13, foodType: 'glitch_frag' },
                // Ring 4
                { type: 'heaven', color: 0xfef08a, x: 9000, z: 0, radius: 850, unlockLevel: 14, foodType: 'halo' },
                { type: 'crystal', color: 0x22d3ee, x: -9000, z: 0, radius: 950, unlockLevel: 15, foodType: 'mana_gem' },
                { type: 'hyper', color: 0xd946ef, x: 0, z: 9000, radius: 1050, unlockLevel: 16, foodType: 'tesseract' },
                { type: 'void', color: 0x000000, x: 0, z: -9000, radius: 1150, unlockLevel: 17, foodType: 'dark_matter' },
                // Ring 5
                { type: 'abstract', color: 0x8b5cf6, x: 9000, z: 9000, radius: 1250, unlockLevel: 18, foodType: 'abstract_thought' },
                { type: 'omni', color: 0xf43f5e, x: -9000, z: 9000, radius: 1400, unlockLevel: 19, foodType: 'omni_seed' },
                { type: 'matrix', color: 0x00ff00, x: -9000, z: -9000, radius: 1600, unlockLevel: 20, foodType: 'source_code' },
                { type: 'tesseract_zone', color: 0x8b5cf6, x: 9000, z: -9000, radius: 1800, unlockLevel: 21, foodType: '4d_cube' },
                // Ring 6 (The Farthest Reaches)
                { type: 'world_tree', color: 0x15803d, x: 14000, z: 0, radius: 2000, unlockLevel: 22, foodType: 'golden_apple' },
                { type: 'quacksar', color: 0xf97316, x: -14000, z: 0, radius: 2200, unlockLevel: 23, foodType: 'accretion_dust' },
                { type: 'simulation', color: 0x22d3ee, x: 0, z: 14000, radius: 2400, unlockLevel: 24, foodType: 'sim_token' },
                { type: 'desk', color: 0x475569, x: 0, z: -14000, radius: 3000, unlockLevel: 25, foodType: 'coffee_cup' }
            ];

            // Render pond areas
            POND_AREAS.forEach(area => {
                const areaGeo = new THREE.CylinderGeometry(area.radius, area.radius, 2, 32);
                const areaMat = new THREE.MeshLambertMaterial({ color: area.color });
                const areaMesh = new THREE.Mesh(areaGeo, areaMat);
                areaMesh.position.set(area.x, 0.5, area.z); // Slightly above base water
                areaMesh.receiveShadow = true;
                scene.add(areaMesh);

                // Forcefield Barrier (Visible until unlocked)
                const barrierGeo = new THREE.CylinderGeometry(area.radius, area.radius, 200 + area.radius*0.2, 32, 1, true);
                const barrierMat = new THREE.MeshBasicMaterial({ 
                    color: area.color, 
                    transparent: true, 
                    opacity: 0.25, 
                    side: THREE.DoubleSide,
                    wireframe: true
                });
                const barrierMesh = new THREE.Mesh(barrierGeo, barrierMat);
                barrierMesh.position.set(area.x, 100 + area.radius*0.1, area.z);
                scene.add(barrierMesh);
                area.barrierMesh = barrierMesh;

                // Area-specific decorations
                if (area.type === 'shallow') {
                    // Sandy rocks
                    for(let i=0; i<20; i++) {
                        const rockGeo = new THREE.DodecahedronGeometry(Math.random() * 15 + 5, 0);
                        const rockMat = new THREE.MeshLambertMaterial({ color: 0x9ca3af });
                        const rock = new THREE.Mesh(rockGeo, rockMat);
                        const angle = Math.random() * Math.PI * 2;
                        const r = Math.random() * area.radius * 0.8;
                        rock.position.set(area.x + Math.cos(angle)*r, 5, area.z + Math.sin(angle)*r);
                        rock.rotation.set(Math.random(), Math.random(), Math.random());
                        rock.castShadow = true;
                        rock.receiveShadow = true;
                        scene.add(rock);
                    }
                } else if (area.type === 'mud') {
                    // Cattails
                    for(let i=0; i<40; i++) {
                        const reedGeo = new THREE.CylinderGeometry(1, 1, Math.random()*15 + 20, 6);
                        const reedMat = new THREE.MeshLambertMaterial({ color: 0x65a30d });
                        const reed = new THREE.Mesh(reedGeo, reedMat);
                        const angle = Math.random() * Math.PI * 2;
                        const r = Math.random() * area.radius * 0.8;
                        reed.position.set(area.x + Math.cos(angle)*r, 10, area.z + Math.sin(angle)*r);
                        
                        const topGeo = new THREE.CylinderGeometry(2, 2, 8, 8);
                        const topMat = new THREE.MeshLambertMaterial({ color: 0x451a03 });
                        const top = new THREE.Mesh(topGeo, topMat);
                        top.position.y = 10;
                        reed.add(top);
                        
                        reed.castShadow = true;
                        scene.add(reed);
                    }
                } else if (area.type === 'mystic') {
                    // Glowing crystals / orbs
                    for(let i=0; i<15; i++) {
                        const orbGeo = new THREE.OctahedronGeometry(Math.random() * 8 + 4, 0);
                        const orbMat = new THREE.MeshLambertMaterial({ color: 0xe879f9, emissive: 0xc026d3, emissiveIntensity: 0.5 });
                        const orb = new THREE.Mesh(orbGeo, orbMat);
                        const angle = Math.random() * Math.PI * 2;
                        const r = Math.random() * area.radius * 0.8;
                        orb.position.set(area.x + Math.cos(angle)*r, Math.random() * 10 + 5, area.z + Math.sin(angle)*r);
                        orb.castShadow = true;
                        scene.add(orb);
                    }
                } else if (area.type === 'cyber') {
                    // Data pillars
                    for(let i=0; i<25; i++) {
                        const pillarGeo = new THREE.BoxGeometry(Math.random() * 15 + 5, Math.random() * 50 + 20, Math.random() * 15 + 5);
                        const pillarMat = new THREE.MeshLambertMaterial({ color: 0x164e63, emissive: 0x06b6d4, emissiveIntensity: 0.4, wireframe: Math.random() > 0.4 });
                        const pillar = new THREE.Mesh(pillarGeo, pillarMat);
                        const angle = Math.random() * Math.PI * 2;
                        const r = Math.random() * area.radius * 0.8;
                        pillar.position.set(area.x + Math.cos(angle)*r, 10, area.z + Math.sin(angle)*r);
                        pillar.castShadow = true;
                        scene.add(pillar);
                    }
                } else if (area.type === 'cosmic') {
                    // Floating asteroids
                    for(let i=0; i<35; i++) {
                        const astGeo = new THREE.DodecahedronGeometry(Math.random() * 15 + 5, 0);
                        const astMat = new THREE.MeshLambertMaterial({ color: 0x475569 });
                        const asteroid = new THREE.Mesh(astGeo, astMat);
                        const angle = Math.random() * Math.PI * 2;
                        const r = Math.random() * area.radius * 0.8;
                        asteroid.position.set(area.x + Math.cos(angle)*r, Math.random() * 50 + 10, area.z + Math.sin(angle)*r);
                        asteroid.rotation.set(Math.random(), Math.random(), Math.random());
                        asteroid.castShadow = true;
                        scene.add(asteroid);
                    }
                } else if (area.type === 'royal') {
                    // Golden pillars
                    for(let i=0; i<15; i++) {
                        const pillarGeo = new THREE.CylinderGeometry(8, 8, 40, 16);
                        const pillarMat = new THREE.MeshLambertMaterial({ color: 0xfbbf24, emissive: 0xb45309 });
                        const pillar = new THREE.Mesh(pillarGeo, pillarMat);
                        const angle = Math.random() * Math.PI * 2;
                        const r = Math.random() * area.radius * 0.8;
                        pillar.position.set(area.x + Math.cos(angle)*r, 20, area.z + Math.sin(angle)*r);
                        pillar.castShadow = true;
                        scene.add(pillar);
                    }
                } else if (area.type === 'quantum') {
                    // Floating geometry
                    for(let i=0; i<20; i++) {
                        const geo = new THREE.IcosahedronGeometry(Math.random() * 10 + 5, 0);
                        const mat = new THREE.MeshLambertMaterial({ color: 0x2dd4bf, transparent: true, opacity: 0.7, wireframe: true });
                        const shape = new THREE.Mesh(geo, mat);
                        const angle = Math.random() * Math.PI * 2;
                        const r = Math.random() * area.radius * 0.8;
                        shape.position.set(area.x + Math.cos(angle)*r, Math.random() * 40 + 10, area.z + Math.sin(angle)*r);
                        shape.rotation.set(Math.random(), Math.random(), Math.random());
                        scene.add(shape);
                    }
                } else if (area.type === 'multiverse') {
                    // Floating Orbs of light
                    for(let i=0; i<20; i++) {
                        const orbGeo = new THREE.SphereGeometry(10, 16, 16);
                        const orbMat = new THREE.MeshBasicMaterial({ color: 0xffffff });
                        const orb = new THREE.Mesh(orbGeo, orbMat);
                        const angle = Math.random() * Math.PI * 2;
                        const r = Math.random() * area.radius * 0.8;
                        orb.position.set(area.x + Math.cos(angle)*r, Math.random() * 60 + 20, area.z + Math.sin(angle)*r);
                        scene.add(orb);
                        
                        const ringGeo = new THREE.RingGeometry(15, 20, 32);
                        const ringMat = new THREE.MeshBasicMaterial({ color: 0xfacc15, side: THREE.DoubleSide });
                        const ring = new THREE.Mesh(ringGeo, ringMat);
                        ring.rotation.x = Math.PI / 2;
                        orb.add(ring);
                    }
                } else if (area.type === 'chrono') {
                    for(let i=0; i<15; i++) {
                        const gearGeo = new THREE.TorusGeometry(Math.random()*20+10, 4, 8, 12);
                        const gear = new THREE.Mesh(gearGeo, new THREE.MeshLambertMaterial({color: 0x78350f}));
                        const angle = Math.random() * Math.PI * 2;
                        const r = Math.random() * area.radius * 0.8;
                        gear.position.set(area.x + Math.cos(angle)*r, 20, area.z + Math.sin(angle)*r);
                        gear.rotation.set(Math.random(), Math.random(), Math.random());
                        scene.add(gear);
                    }
                } else if (area.type === 'magma') {
                    for(let i=0; i<20; i++) {
                        const spoutGeo = new THREE.ConeGeometry(Math.random()*15+5, Math.random()*60+20, 8);
                        const spout = new THREE.Mesh(spoutGeo, new THREE.MeshLambertMaterial({color: 0x7f1d1d, emissive: 0xb91c1c}));
                        const angle = Math.random() * Math.PI * 2;
                        const r = Math.random() * area.radius * 0.8;
                        spout.position.set(area.x + Math.cos(angle)*r, 10, area.z + Math.sin(angle)*r);
                        scene.add(spout);
                    }
                } else if (area.type === 'glitch') {
                    for(let i=0; i<30; i++) {
                        const boxGeo = new THREE.BoxGeometry(Math.random()*30+10, Math.random()*30+10, Math.random()*30+10);
                        const box = new THREE.Mesh(boxGeo, new THREE.MeshBasicMaterial({color: 0x10b981, wireframe: true}));
                        const angle = Math.random() * Math.PI * 2;
                        const r = Math.random() * area.radius * 0.8;
                        box.position.set(area.x + Math.cos(angle)*r, Math.random()*50, area.z + Math.sin(angle)*r);
                        scene.add(box);
                    }
                } else if (area.type === 'heaven') {
                    for(let i=0; i<25; i++) {
                        const cloudGeo = new THREE.DodecahedronGeometry(Math.random()*30+15, 1);
                        const cloud = new THREE.Mesh(cloudGeo, new THREE.MeshLambertMaterial({color: 0xffffff, transparent: true, opacity: 0.8}));
                        const angle = Math.random() * Math.PI * 2;
                        const r = Math.random() * area.radius * 0.8;
                        cloud.position.set(area.x + Math.cos(angle)*r, Math.random()*100+40, area.z + Math.sin(angle)*r);
                        scene.add(cloud);
                    }
                } else if (area.type === 'crystal') {
                    for(let i=0; i<25; i++) {
                        const cryGeo = new THREE.OctahedronGeometry(Math.random()*20+10, 0);
                        const cry = new THREE.Mesh(cryGeo, new THREE.MeshLambertMaterial({color: 0x67e8f9, emissive: 0x0891b2}));
                        const angle = Math.random() * Math.PI * 2;
                        const r = Math.random() * area.radius * 0.8;
                        cry.position.set(area.x + Math.cos(angle)*r, Math.random()*40, area.z + Math.sin(angle)*r);
                        cry.scale.set(1, 2.5, 1);
                        scene.add(cry);
                    }
                } else if (area.type === 'hyper') {
                    for(let i=0; i<15; i++) {
                        const hypGeo = new THREE.OctahedronGeometry(Math.random()*40+20, 0);
                        const hyp = new THREE.Mesh(hypGeo, new THREE.MeshLambertMaterial({color: 0xd946ef, wireframe: true}));
                        const angle = Math.random() * Math.PI * 2;
                        const r = Math.random() * area.radius * 0.8;
                        hyp.position.set(area.x + Math.cos(angle)*r, Math.random()*80+20, area.z + Math.sin(angle)*r);
                        scene.add(hyp);
                    }
                } else if (area.type === 'matrix') {
                    for(let i=0; i<40; i++) {
                        const colGeo = new THREE.CylinderGeometry(5, 5, Math.random()*200+50, 4);
                        const col = new THREE.Mesh(colGeo, new THREE.MeshBasicMaterial({color: 0x00ff00, wireframe: true}));
                        const angle = Math.random() * Math.PI * 2;
                        const r = Math.random() * area.radius * 0.8;
                        col.position.set(area.x + Math.cos(angle)*r, 0, area.z + Math.sin(angle)*r);
                        scene.add(col);
                    }
                } else if (area.type === 'tesseract_zone') {
                    for(let i=0; i<20; i++) {
                        const m = new THREE.Mesh(new THREE.BoxGeometry(Math.random()*40+20, Math.random()*40+20, Math.random()*40+20), new THREE.MeshBasicMaterial({color: 0x8b5cf6, wireframe: true}));
                        const angle = Math.random() * Math.PI * 2;
                        const r = Math.random() * area.radius * 0.8;
                        m.position.set(area.x + Math.cos(angle)*r, Math.random()*100+20, area.z + Math.sin(angle)*r);
                        m.rotation.set(Math.random(), Math.random(), Math.random());
                        scene.add(m);
                    }
                } else if (area.type === 'world_tree') {
                    for(let i=0; i<25; i++) {
