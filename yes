            function loadPlayerModel(stageIndex) {
                if (player.modelGroup) {
                    player.group.remove(player.modelGroup);
                }
                player.modelGroup = new THREE.Group();
                player.group.add(player.modelGroup);
                
                const stage = EVOLUTIONS[stageIndex];
                player.group.userData.wings = buildStageModel(stageIndex, player.modelGroup, stage.size, stage.colors);
                updateUI();
            }

            // PERFORMANCE: Prefab Cache to stop creating 2,000 unique geometries!
            const foodPrefabCache = {};

            // Factory: Build Custom Food Models
            function createFoodMesh(type) {
                if (foodPrefabCache[type.type]) {
                    // Instantly clone the existing template (Shares memory/geometries!)
                    return foodPrefabCache[type.type].clone();
                }

                const group = new THREE.Group();
                const mat = new THREE.MeshLambertMaterial({ color: type.color });
                
                if (type.type === 'seed') {
                    const mesh = new THREE.Mesh(new THREE.DodecahedronGeometry(type.size, 0), mat);
                    group.add(mesh);
                } else if (type.type === 'bread') {
                    const mesh1 = new THREE.Mesh(new THREE.BoxGeometry(type.size, type.size*0.8, type.size*0.2), mat);
                    const mesh2 = new THREE.Mesh(new THREE.CylinderGeometry(type.size*0.5, type.size*0.5, type.size*0.2, 16), mat);
                    mesh2.rotation.x = Math.PI/2;
                    mesh2.position.y = type.size*0.4;
                    group.add(mesh1, mesh2);
                } else if (type.type === 'bug') {
                    const b1 = new THREE.Mesh(new THREE.SphereGeometry(type.size*0.5, 8, 8), mat);
                    const b2 = new THREE.Mesh(new THREE.SphereGeometry(type.size*0.4, 8, 8), mat);
                    b2.position.z = -type.size*0.7;
                    const b3 = new THREE.Mesh(new THREE.SphereGeometry(type.size*0.3, 8, 8), mat);
                    b3.position.z = -type.size*1.2;
                    group.add(b1, b2, b3);
                } else if (type.type === 'fish') {
                    const body = new THREE.Mesh(new THREE.ConeGeometry(type.size*0.5, type.size*2, 8), mat);
                    body.rotation.x = Math.PI/2;
                    const tailMat = new THREE.MeshLambertMaterial({ color: 0x60a5fa });
                    const tail = new THREE.Mesh(new THREE.ConeGeometry(type.size*0.6, type.size*1.2, 4), tailMat);
                    tail.position.z = -type.size;
                    tail.rotation.x = -Math.PI/2;
                    group.add(body, tail);
                    
                    const eyeMat = new THREE.MeshBasicMaterial({color: 0x000000});
                    const eyeL = new THREE.Mesh(new THREE.SphereGeometry(type.size*0.1, 4, 4), eyeMat);
                    eyeL.position.set(type.size*0.3, type.size*0.2, type.size*0.5);
                    const eyeR = eyeL.clone();
                    eyeR.position.set(-type.size*0.3, type.size*0.2, type.size*0.5);
                    group.add(eyeL, eyeR);
                } else if (type.type === 'star') {
                    const mesh = new THREE.Mesh(new THREE.OctahedronGeometry(type.size, 0), mat);
                    const glowMat = new THREE.MeshBasicMaterial({color: 0xffffff, transparent: true, opacity: 0.5});
                    const glow = new THREE.Mesh(new THREE.OctahedronGeometry(type.size*1.3, 0), glowMat);
                    group.add(mesh, glow);
                } else if (type.type === 'battery') {
                    const body = new THREE.Mesh(new THREE.CylinderGeometry(type.size*0.4, type.size*0.4, type.size*1.2, 12), mat);
                    body.rotation.x = Math.PI / 2;
                    const nodeMat = new THREE.MeshLambertMaterial({color: 0xfacc15}); // Yellow tip
                    const node = new THREE.Mesh(new THREE.CylinderGeometry(type.size*0.2, type.size*0.2, type.size*0.2, 12), nodeMat);
                    node.rotation.x = Math.PI / 2;
                    node.position.z = type.size*0.6;
                    group.add(body, node);
                } else if (type.type === 'galaxy_core') {
                    const core = new THREE.Mesh(new THREE.SphereGeometry(type.size*0.5, 16, 16), mat);
                    const ringMat = new THREE.MeshBasicMaterial({color: 0x8b5cf6, transparent: true, opacity: 0.7, side: THREE.DoubleSide});
                    const ring = new THREE.Mesh(new THREE.RingGeometry(type.size*0.7, type.size, 32), ringMat);
                    ring.rotation.x = Math.PI / 3;
                    group.add(core, ring);
                } else if (type.type === 'golden_egg') {
                    const mesh = new THREE.Mesh(new THREE.SphereGeometry(type.size, 16, 16), mat);
                    mesh.scale.set(1, 1.3, 1);
                    group.add(mesh);
                } else if (type.type === 'quark') {
                    const core = new THREE.Mesh(new THREE.SphereGeometry(type.size*0.4, 8, 8), mat);
                    const ringMat = new THREE.MeshBasicMaterial({ color: type.color, side: THREE.DoubleSide, wireframe: true });
                    const r1 = new THREE.Mesh(new THREE.TorusGeometry(type.size, type.size*0.1, 8, 16), ringMat);
                    const r2 = new THREE.Mesh(new THREE.TorusGeometry(type.size, type.size*0.1, 8, 16), ringMat);
                    r2.rotation.x = Math.PI / 2;
                    group.add(core, r1, r2);
                } else if (type.type === 'universe') {
                    const coreMat = new THREE.MeshBasicMaterial({ color: 0x000000 }); // Black hole core
