                    addEye(bSize*0.3, bSize*1.75, bSize*0.95, bSize*0.1);
                    addEye(-bSize*0.3, bSize*1.75, bSize*0.95, bSize*0.1);

                    wings.push(createWing(bSize*0.9, bSize*0.2, bSize*0.6, bSize*1.0, bodyMat));
                    wings.push(createWing(-bSize*0.9, bSize*0.2, bSize*0.6, bSize*1.0, bodyMat));

                } else if (stageIndex === 1) { // Normal Duck
                    const body = new THREE.Mesh(new THREE.SphereGeometry(bSize, 16, 16), bodyMat);
                    body.scale.set(0.9, 0.8, 1.3);
                    body.position.y = bSize * 0.9;
                    container.add(body);

                    const tail = new THREE.Mesh(new THREE.ConeGeometry(bSize*0.4, bSize, 8), bodyMat);
                    tail.rotation.x = -Math.PI / 2 + 0.3;
                    tail.position.set(0, bSize*1.1, -bSize*1.1);
                    container.add(tail);

                    const head = new THREE.Mesh(new THREE.SphereGeometry(bSize*0.6, 16, 16), headMat);
                    head.position.set(0, bSize*1.8, bSize*0.7);
                    container.add(head);

                    // Flat beak
                    const beak = new THREE.Mesh(new THREE.BoxGeometry(bSize*0.4, bSize*0.15, bSize*0.8), beakMat);
                    beak.position.set(0, bSize*1.7, bSize*1.2);
                    container.add(beak);

                    addEye(bSize*0.25, bSize*1.85, bSize*1.1, bSize*0.08);
                    addEye(-bSize*0.25, bSize*1.85, bSize*1.1, bSize*0.08);

                    wings.push(createWing(bSize*0.8, bSize*0.2, bSize*0.6, bSize*1.4, bodyMat));
                    wings.push(createWing(-bSize*0.8, bSize*0.2, bSize*0.6, bSize*1.4, bodyMat));

                } else if (stageIndex === 2) { // Wild Goose
                    const body = new THREE.Mesh(new THREE.SphereGeometry(bSize, 16, 16), bodyMat);
                    body.scale.set(0.8, 0.8, 1.4);
                    body.position.y = bSize * 0.9;
