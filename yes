                    const mesh = new THREE.Mesh(new THREE.BoxGeometry(sizeX, sizeY, sizeZ), mat);
                    mesh.position.set(x > 0 ? sizeX/2 : -sizeX/2, 0, 0);
                    pivot.add(mesh);
                    container.add(pivot);
                    return pivot;
                }

                // Helper: Eyes
                function addEye(x, y, z, r) {
                    const eye = new THREE.Mesh(new THREE.SphereGeometry(r, 8, 8), eyeMat);
                    eye.position.set(x, y, z);
                    container.add(eye);
                }

                if (stageIndex === 0) { // Baby Duck
                    const body = new THREE.Mesh(new THREE.SphereGeometry(bSize, 16, 16), bodyMat);
