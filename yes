                    container.add(beak);

                    const glowEyeMat = new THREE.MeshBasicMaterial({color: 0x06b6d4}); // Cyan
                    const eyeL = new THREE.Mesh(new THREE.BoxGeometry(bSize*0.2, bSize*0.1, bSize*0.1), glowEyeMat);
                    eyeL.position.set(bSize*0.25, bSize*2.4, bSize*1.55);
                    const eyeR = eyeL.clone();
                    eyeR.position.set(-bSize*0.25, bSize*2.4, bSize*1.55);
                    container.add(eyeL, eyeR);

                    const antenna = new THREE.Mesh(new THREE.CylinderGeometry(bSize*0.05, bSize*0.05, bSize*0.6), beakMat);
                    antenna.position.set(0, bSize*2.8, bSize*1.0);
                    const bulb = new THREE.Mesh(new THREE.SphereGeometry(bSize*0.15, 8, 8), glowEyeMat);
                    bulb.position.set(0, bSize*3.1, bSize*1.0);
                    container.add(antenna, bulb);

                    wings.push(createWing(bSize*0.9, bSize*0.3, bSize*0.2, bSize*1.6, headMat));
                    wings.push(createWing(-bSize*0.9, bSize*0.3, bSize*0.2, bSize*1.6, headMat));

                } else if (stageIndex === 6) { // Cosmic Dragon
                    // Serpentine body
                    const numBodyParts = 6;
                    for(let i=0; i<numBodyParts; i++) {
                        const zPos = -i * bSize * 0.8;
                        const scale = 1 - (i * 0.1);
                        const bPart = new THREE.Mesh(new THREE.SphereGeometry(bSize * scale, 16, 16), bodyMat);
                        bPart.scale.set(1, 0.8, 1.2);
                        bPart.position.set(0, bSize, zPos);
                        
                        const spike = new THREE.Mesh(new THREE.ConeGeometry(bSize*0.2*scale, bSize*0.6*scale, 4), beakMat);
                        spike.position.set(0, bSize*1.5*scale, zPos);
                        container.add(bPart, spike);
                    }

                    const neck = new THREE.Mesh(new THREE.CylinderGeometry(bSize*0.4, bSize*0.6, bSize*1.5, 16), bodyMat);
                    neck.rotation.x = Math.PI / 4;
                    neck.position.set(0, bSize*1.6, bSize*0.6);
                    container.add(neck);

                    const head = new THREE.Mesh(new THREE.BoxGeometry(bSize*0.8, bSize*0.6, bSize*1.2), headMat);
                    head.position.set(0, bSize*2.0, bSize*1.2);
