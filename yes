                    beak.rotation.x = Math.PI / 2;
                    beak.position.set(0, bSize*2.3, bSize*1.2);
                    container.add(beak);

                    // Floating quantum orbs instead of wings
                    wings.push(createWing(bSize*1.2, bSize*0.5, bSize*0.5, bSize*0.5, qMat));
                    wings.push(createWing(-bSize*1.2, bSize*0.5, bSize*0.5, bSize*0.5, qMat));

                } else if (stageIndex === 9) { // Multiverse Creator
                    const godMat = new THREE.MeshLambertMaterial({ color: colors.body, emissive: 0x442200 });
                    const ringMat = new THREE.MeshBasicMaterial({ color: 0xffffff, side: THREE.DoubleSide });

