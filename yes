                    neck.position.set(0, bSize*1.6, bSize*0.8);
                    container.add(neck);

                    const head = new THREE.Mesh(new THREE.SphereGeometry(bSize*0.5, 16, 16), headMat);
                    head.position.set(0, bSize*2.2, bSize*1.1);
                    container.add(head);

                    const beak = new THREE.Mesh(new THREE.ConeGeometry(bSize*0.3, bSize, 8), beakMat);
                    beak.rotation.x = Math.PI / 2;
                    beak.position.set(0, bSize*2.1, bSize*1.6);
                    container.add(beak);

                    addEye(bSize*0.25, bSize*2.25, bSize*1.3, bSize*0.08);
                    addEye(-bSize*0.25, bSize*2.25, bSize*1.3, bSize*0.08);

                    wings.push(createWing(bSize*0.7, bSize*0.2, bSize*0.6, bSize*1.8, bodyMat));
                    wings.push(createWing(-bSize*0.7, bSize*0.2, bSize*0.6, bSize*1.8, bodyMat));

                } else if (stageIndex === 3) { // Swan
                    const body = new THREE.Mesh(new THREE.SphereGeometry(bSize, 16, 16), bodyMat);
